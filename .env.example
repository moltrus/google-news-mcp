# Google News MCP Server Configuration

# Optional: Language and location settings
GOOGLE_NEWS_LANGUAGE="en"
GOOGLE_NEWS_COUNTRY="US"

# Response format settings for API responses.

# Options: "json" or "toon"
# "json" - Standard JSON format (default)
# "toon" - Token-Oriented Object Notation (30-60% token reduction)
RESPONSE_FORMAT="toon"

# Jina Reader API configuration
JINA_API_KEY="JINA_API_KEY"
JINA_READER_ENGINE="cf-browser-rendering"
JINA_READER_RETAIN_IMAGES="none"

# Optional: Groq summarization settings (used when fetch_content(..., summarize=true))
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="qwen/qwen3-32b"
GROQ_SUMMARY_MAX_TOKENS="400"
