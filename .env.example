# Google News MCP Server Configuration

# Optional: Language and location settings
GOOGLE_NEWS_LANGUAGE="en"
GOOGLE_NEWS_COUNTRY="US"

# Response format settings for API responses.

# Options: "json" or "toon"
# "json" - Standard JSON format (default)
# "toon" - Token-Oriented Object Notation (30-60% token reduction)
RESPONSE_FORMAT="toon"
